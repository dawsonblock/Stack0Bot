{
  "name": "agent-stack-best",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/shell",
    "packages/agent-kernel",
    "services/run-api",
    "services/sandbox"
  ],
  "scripts": {
    "install": "node ./scripts/install-core.mjs",
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "lint": "node ./scripts/lint-core.mjs",
    "test": "node ./scripts/run-core-tests.mjs",
    "test:coverage": "c8 node ./scripts/run-core-tests.mjs",
    "verify": "node ./scripts/verify-core.mjs",
    "verify:live": "node ./scripts/verify-core.mjs --smoke",
    "smoke": "./scripts/smoke-local-stack.sh",
    "start:run-api": "npm run start --workspace services/run-api"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "c8": "^10.1.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}