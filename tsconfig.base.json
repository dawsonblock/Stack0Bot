{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "baseUrl": ".",
    "paths": {
      "@agent-stack/agent-kernel": [
        "packages/agent-kernel/src/index.ts"
      ],
      "@agent-stack/sandbox": [
        "services/sandbox/index.ts"
      ]
    },
    "types": [
      "node"
    ],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true
  }
}